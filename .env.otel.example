# OpenTelemetry Environment Variables for Kibana Python Client
#
# Copy this file to .env and customize as needed.
# These environment variables configure OpenTelemetry observability.

# Enable OpenTelemetry instrumentation
KIBANA_OTEL_ENABLED=true

# Auto-configure on import (optional)
KIBANA_OTEL_AUTO_CONFIGURE=false

# Service name for traces
OTEL_SERVICE_NAME=kibana-py

# Exporter type: otlp, console
KIBANA_OTEL_EXPORTER=otlp

# OTLP endpoint
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# OTLP protocol: grpc or http/protobuf
OTEL_EXPORTER_OTLP_PROTOCOL=grpc

# OTLP headers (optional, for authentication)
# OTEL_EXPORTER_OTLP_HEADERS=api-key=your-api-key

# Resource attributes
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=development,service.version=0.1.0

# Sampling rate (0.0 to 1.0)
OTEL_TRACES_SAMPLER=parentbased_traceidratio
OTEL_TRACES_SAMPLER_ARG=1.0

# Log level for OpenTelemetry
OTEL_LOG_LEVEL=info
