# Definition-of-Done criteria for kibana-py.
# Each criterion is `required` or `n/a`. The gate (scripts/checks/definition-of-done.sh)
# runs every REQUIRED check and emits GO / NO-GO — completion and release claims are
# certified by tooling, never self-certified by the author (human or agent).
# Criteria delegate to make leaves; the Makefile recipes are the single source.
#
# Concept adapted from cmanaha/extended-superpowers (MIT).

unit_green = required
types_clean = required
hygiene_hooks = required
audit_clean = required
sast_clean = required
docs_strict = required
# Make targets conform to the methodology's shared vocabulary
# (skills/dev-environment-facade/vocabulary.txt).
vocabulary_conformant = required
# Needs the local Elastic Stack (docker); their make targets start it.
integration_green = required
benchmark_green = required
# "Required before release" per the Makefile — nox across supported Pythons.
# Fail-closed: make test-python-matrix passes --error-on-missing-interpreters, so
# a host missing any supported interpreter NO-GOs instead of under-certifying (#29).
matrix_green = required
changelog_entry = required
