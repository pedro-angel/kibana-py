# elastic-start-local — local/CI dev environment template.
#
# Copy to `.env` before starting the stack:  cp .env.example .env
# All values below are NON-SECRET local development defaults (the `.env` pattern
# is un-committable by .gitignore; this template is the sanctioned way back in).
# `make stack-start` / local-stack.sh and the integration-probe workflow both
# consume `.env`, so this file is the single source of truth for those defaults.

ES_LOCAL_VERSION=9.4.3
ES_LOCAL_CONTAINER_NAME=kibana-py-es-local
ES_LOCAL_PORT=9200
ES_LOCAL_URL=http://localhost:9200
ES_LOCAL_PASSWORD=kibana-py-es-dev
ES_LOCAL_JAVA_OPTS="-Xms2g -Xmx2g"
ES_LOCAL_DISK_SPACE_REQUIRED=1gb
# Left blank on purpose: local-stack.sh mints an API key on first start and
# writes it to the untracked .env.local.
ES_LOCAL_API_KEY=
ES_LOCAL_LICENSE_EXPIRE_DATE=4102444800

KIBANA_LOCAL_CONTAINER_NAME=kibana-py-kibana-local
KIBANA_LOCAL_SETTINGS_CONTAINER_NAME=kibana-py-kibana-settings
KIBANA_LOCAL_PORT=5601
KIBANA_LOCAL_URL=http://localhost:5601
KIBANA_LOCAL_PASSWORD=kibana-py-kbn-dev
KIBANA_ENCRYPTION_KEY=kibana-py-dev-encryption-key-0123456789abcdef

APM_LOCAL_CONTAINER_NAME=kibana-py-apm-local
APM_LOCAL_PORT=8200
ELASTIC_APM_SECRET_TOKEN=kibana-py-dev-apm-token

# Consumed by the integration test suite (tests/integration/utils.py).
KIBANA_USERNAME=elastic
KIBANA_PASSWORD=kibana-py-es-dev
